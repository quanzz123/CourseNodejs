<div class="mt-4">
    <h3>Đăng ký khóa học mới</h3>

    <!-- Khi nhấn submit, form sẽ gửi request POST tới đường dẫn /courses/store -->
    <form method="POST" action="/courses/store">
        <div class="form-group mb-3">
            <label for="name" class="form-label">Tên khóa học</label>
            <input type="text" class="form-control" id="name" name="name" required placeholder="Nhập tên khóa học...">
        </div>

        <div class="form-group mb-3">
            <label for="description" class="form-label">Mô tả khóa học</label>
            <textarea class="form-control" id="description" name="description" rows="3" required placeholder="Nhập mô tả ngắn..."></textarea>
        </div>

        <div class="form-group mb-3">
            <label for="image" class="form-label">Hình ảnh đại diện (Link URL)</label>
            <input type="text" class="form-control" id="image" name="image" required placeholder="Nhập link ảnh minh họa...">
        </div>

        <div class="form-group mb-3">
            <label for="videoId" class="form-label">Mã Video (YouTube Video ID)</label>
            <input type="text" class="form-control" id="videoId" name="videoId" required placeholder="Ví dụ: dWpC08p2v1M">
        </div>

        <button type="submit" class="btn btn-primary">Thêm khóa học</button>
    </form>
</div>