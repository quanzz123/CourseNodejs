<div class="mt-4">
    <h3>Đăng ký khóa học mới</h3>

    <!-- Khi nhấn submit, form sẽ gửi request POST tới đường dẫn /courses/store -->
    <form method="POST" action="/courses/{{course._id}}?_method=PUT">
        <div class="form-group mb-3">
            <label for="name" class="form-label">Tên khóa học</label>
            <input type="text" class="form-control" id="name" name="name" value="{{course.name}}" required placeholder="Nhập tên khóa học...">
        </div>

        <div class="form-group mb-3">
            <label for="description" class="form-label">Mô tả khóa học</label>
            <textarea class="form-control" id="description" name="description"  rows="3" required placeholder="Nhập mô tả ngắn...">{{course.description}}</textarea>
        </div>

        <div class="form-group mb-3">
            <label for="image" class="form-label">Hình ảnh đại diện (Link URL)</label>
            <input type="text" class="form-control" id="image" name="image" value="{{course.image}}" required placeholder="Nhập link ảnh minh họa...">
        </div>

        <div class="form-group mb-3">
            <label for="videoId" class="form-label">Mã Video (YouTube Video ID)</label>
            <input type="text" class="form-control" id="videoId" name="videoId" value="{{course.videoId}}" required placeholder="Ví dụ: dWpC08p2v1M">
        </div>

        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    </form>
</div>